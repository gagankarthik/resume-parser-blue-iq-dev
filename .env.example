# ─── App ────────────────────────────────────────────────────────────────────
APP_NAME="Resume Parser API"
APP_VERSION="1.0.0"
ENVIRONMENT="development"        # development | production
DEBUG=false

# ─── AWS ────────────────────────────────────────────────────────────────────
AWS_REGION="us-east-2"
AWS_ACCESS_KEY_ID="your-access-key-id"
AWS_SECRET_ACCESS_KEY="your-secret-access-key"

# Leave empty in production (uses IAM roles). Set for LocalStack in dev:
DYNAMODB_ENDPOINT_URL="http://localhost:4566"
S3_ENDPOINT_URL="http://localhost:4566"
TEXTRACT_ENDPOINT_URL=""         # Leave empty — always hits real AWS Textract

# ─── OCR ────────────────────────────────────────────────────────────────────
# Skip Tesseract and use AWS Textract directly for ALL scanned PDFs/images.
# Leave "false" to keep the tiered default (Tesseract first, Textract only when
# confidence is low). Callers can also force it per-request with the
# `force_textract` flag on the parse endpoints.
FORCE_TEXTRACT="false"

# ─── DynamoDB Tables ────────────────────────────────────────────────────────
DYNAMODB_TABLE_API_KEYS="resume-parser-api-keys"
DYNAMODB_TABLE_JOBS="resume-parser-jobs"
DYNAMODB_TABLE_BATCHES="resume-parser-batches"
DYNAMODB_TABLE_WEBHOOKS="resume-parser-webhooks"
DYNAMODB_TABLE_AUDIT_LOGS="resume-parser-audit-logs"
DYNAMODB_TABLE_COMPANIES="resume-parser-companies"
DYNAMODB_TABLE_FEEDBACK="resume-parser-feedback"

# GSI names (defaults shown — only override if you renamed the indexes)
# AUDIT_LOGS_COMPANY_INDEX="company-timestamp-index"
# COMPANIES_EMAIL_INDEX="email-index"
# API_KEYS_COMPANY_INDEX="company-index"

# ─── Admin API (product platform: companies, keys, usage) ─────────────────────
# Bearer token (X-Admin-Token) for /api/v1/admin/*. Empty = admin API disabled.
ADMIN_API_TOKEN=""

# ─── Auth (self-serve account session tokens) ────────────────────────────────
# HMAC secret signing /api/v1/auth session tokens. REQUIRED in production — the
# in-code default is insecure and a deploy with it is blocked by Terraform.
# Generate: openssl rand -hex 32  (or: python -c "import secrets; print(secrets.token_hex(32))")
AUTH_SECRET=""

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated allowed origins. Empty denies cross-origin in production
# (dev falls back to "*"). e.g. "https://app.example.com,https://admin.example.com"
CORS_ALLOWED_ORIGINS=""

# ─── S3 ─────────────────────────────────────────────────────────────────────
S3_BUCKET_NAME="resume-parser-blue-iq-temp"

# ─── OpenAI ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY="sk-proj-replace-with-your-key"
OPENAI_MODEL="gpt-4.1-mini"
OPENAI_MAX_TOKENS=16384

# ─── Multi-agent parser ─────────────────────────────────────────────────────
# true  = high-accuracy orchestrator (structure → per-role work extraction →
#         parallel section agents → bullet-count validation); single-shot is the
#         automatic fallback if it fails.
# false = single-shot structured-output parser only (fewer LLM calls, lower cost).
USE_MULTI_AGENT=true
# Max concurrent in-flight LLM calls across the whole pipeline (caps fan-out on
# long / travel-nurse résumés so the OpenAI TPM ceiling isn't tripped).
MULTI_AGENT_MAX_CONCURRENCY=4
# Complexity gate: only résumés with at least this many cleaned characters use
# the multi-agent path; shorter ones use the fast single-shot parser. 0 = always
# multi-agent when enabled.
MULTI_AGENT_MIN_CHARS=3500

# ─── Specialty → ID matching ─────────────────────────────────────────────────
# Per-role specialties are mapped to the platform's specialty ids via a tiered
# match (name → full name → keywords → batched AI shortlist). Unmatched
# specialties are kept WITHOUT an id (for admin review), never dropped.
#
# The catalog is a snapshot of the GigHealth specialties API, bundled at
# app/data/specialty_catalog.json and refreshed by:
#     python -m scripts.refresh_specialty_catalog
# Override the path only if you host the catalog elsewhere; leaving it unset uses
# the bundled snapshot.
# SPECIALTY_CATALOG_PATH="app/data/specialty_catalog.json"
#
# GigHealth Partner API key (x-api-key). ONE key for every Gig endpoint below.
# Both spellings are accepted (GIG_SPECIALTIES_API_KEY / GIG_SPECIAILITIES_API_KEY);
# the refresh scripts read it to rebuild snapshots, and the LIVE cities lookup reads
# it at parse time. Facility/geography/specialty ids resolve OFFLINE from bundled
# snapshots and never need it.
GIG_SPECIAILITIES_API_KEY="replace-with-your-gig-api-key"
GIG_SPECIALTIES_API_URL="https://api.gighealth.com/api/v1/external/specialities"
# Toggle the batched AI fallback tier (tier 4) and cap its shortlist size.
ENABLE_AI_SPECIALTY_MATCH=true
SPECIALTY_AI_SHORTLIST_MAX=60
#
# Facility + geography catalogs (bundled snapshots; refresh scripts regenerate them).
# FACILITY_CATALOG_PATH="app/data/facility_catalog.json"
# GEOGRAPHY_CATALOG_PATH="app/data/geography_catalog.json"
GIG_FACILITIES_API_URL="https://api.gighealth.com/api/v1/external/facilities"
GIG_GEOGRAPHIES_API_URL="https://api.gighealth.com/api/v1/external/geographies"
# Cities are a LIVE per-parse fuzzy search (no snapshot). ON by default; a no-op
# when no API key is set. Lookups are deduped and capped per résumé.
GIG_CITIES_API_URL="https://api.gighealth.com/api/v1/external/cities"
ENABLE_CITY_API_MATCH=true
CITY_API_MAX_LOOKUPS=25

# ─── Processing ─────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=10
JOB_RESULT_TTL_SECONDS=3600     # 1 hour — async results live in DynamoDB

# ─── Rate limiting ───────────────────────────────────────────────────────────
# Per-API-key throttle, fixed 60s window, enforced in the auth dependency.
# Best-effort PER Lambda instance — front with an API Gateway usage plan / Redis
# for a strict global cap. DISABLED by default during client testing; set
# RATE_LIMIT_ENABLED=true to enforce it, and tune RATE_LIMIT_PER_MINUTE.
RATE_LIMIT_ENABLED=false
RATE_LIMIT_PER_MINUTE=600
# Bytes of multipart/header overhead allowed ABOVE MAX_FILE_SIZE_MB before a
# request body is rejected (413) from its Content-Length, pre-read.
MAX_REQUEST_OVERHEAD_BYTES=1048576

# ─── Webhooks ────────────────────────────────────────────────────────────────
WEBHOOK_TIMEOUT_SECONDS=10
WEBHOOK_MAX_RETRIES=3

# ─── Batch processing ────────────────────────────────────────────────────────
MAX_BATCH_SIZE=200           # max files per batch upload
MAX_CONCURRENT_JOBS=5        # concurrent pipelines locally (Lambda: use reserved concurrency)

# ─── Lambda (production only) ────────────────────────────────────────────────
# Set to the worker Lambda function name when deploying to AWS Lambda.
# Leave empty in development — BackgroundTasks is used instead.
WORKER_LAMBDA_FUNCTION_NAME=""
