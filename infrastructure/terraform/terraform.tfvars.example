# Copy to terraform.tfvars and fill in values. Never commit terraform.tfvars.

aws_region   = "us-east-2"
environment  = "production"
github_owner = "your-github-username"   # personal username OR org name
github_repo  = "resume-parser-blue-iq-dev"

# Passed via CI env var (TF_VAR_openai_api_key) or secrets manager — do NOT put real key here
openai_api_key = "sk-proj-..."

# GigHealth Partner API key (x-api-key). Enables the LIVE cities lookup at parse
# time; facility/geography/specialty ids resolve offline and do NOT need it. Leave
# empty to keep city mapping a safe no-op. Provide via TF_VAR_gig_specialties_api_key
# or here in your local (uncommitted) terraform.tfvars — do NOT commit a real key.
gig_specialties_api_key = ""

# Bearer token gating /api/v1/admin/* (product platform). Generate: openssl rand -hex 32
admin_api_token = ""

# HMAC secret for self-serve account session tokens. REQUIRED in production.
# Generate: openssl rand -hex 32  (or: python -c "import secrets; print(secrets.token_hex(32))")
auth_secret = "replace-me-with-a-32-byte-random-hex-string"

# Set after first docker push (chicken-and-egg: ECR repo must exist first)
ecr_image_uri = "123456789012.dkr.ecr.us-east-2.amazonaws.com/resume-parser-production-lambda:latest"

# Single function serves both the HTTP API and the async OCR path — size for OCR.
api_lambda_memory_mb       = 2048
api_lambda_timeout_seconds = 300

# Custom API domain (optional). Set to front the Lambda Function URL with
# CloudFront + an ACM cert on this hostname. DNS is added manually at GoDaddy
# (see cloudfront_api.tf for the two-phase apply). Leave empty to disable.
api_custom_domain = "api.parsinglab.blue-iq.ai"
